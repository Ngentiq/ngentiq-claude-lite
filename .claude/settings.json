{
  "permissions": {
    "defaultMode": "acceptEdits",
    "allow": [
      "Read",
      "Edit",
      "Write",
      "MultiEdit",
      "Glob",
      "Grep",
      "Skill",
      "WebSearch",
      "Bash(cat:*)",
      "Bash(diff:*)",
      "Bash(sort:*)",
      "Bash(head:*)",
      "Bash(tail:*)",
      "Bash(wc:*)",
      "Bash(cd:*)",
      "Bash(bash --version:*)",
      "Bash(jq:*)",
      "Bash(yq:*)",
      "Bash(date:*)",
      "Bash(realpath:*)",
      "Bash(mkdir:*)",
      "Bash(cp:*)",
      "Bash(ls:*)",
      "Bash(chmod:*)",
      "Bash(touch:*)",
      "Bash(npm run:*)",
      "Bash(npm test:*)",
      "Bash(npm install:*)",
      "Bash(npm --prefix:*)",
      "Bash(npx vitest:*)",
      "Bash(npx tsc:*)",
      "Bash(node .claude/sdlc/:*)",
      "Bash(git -C *)",
      "Bash(git status:*)",
      "Bash(git log:*)",
      "Bash(git diff:*)",
      "Bash(git add:*)",
      "Bash(git branch:*)",
      "Bash(git show:*)",
      "Bash(git fetch:*)",
      "Bash(git stash:*)",
      "Bash(git rev-parse:*)",
      "Bash(git describe:*)",
      "Bash(git remote:*)"
    ],
    "ask": [
      "Bash(rm:*)",
      "Bash(mv:*)"
    ],
    "deny": [
      "Bash(sudo:*)",
      "Bash(git push --force:*)",
      "Bash(git push -f:*)",
      "Bash(git reset --hard:*)",
      "Bash(git rebase:*)",
      "Bash(git clean -f:*)",
      "Bash(git checkout --:*)"
    ]
  },
  "hooks": {
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node $CLAUDE_PROJECT_DIR/.claude/sdlc/hooks/sdlc-hook.js prompt",
            "timeout": 5000
          }
        ]
      }
    ],
    "SubagentStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node $CLAUDE_PROJECT_DIR/.claude/sdlc/hooks/sdlc-hook.js agent",
            "timeout": 5000
          }
        ]
      }
    ]
  }
}
